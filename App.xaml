<Application x:Class="Imagefilter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
        <Application.Resources>
                <!-- 柔和主色 -->
                <SolidColorBrush x:Key="AccentColor"
                                 Color="#5B9BD5"/>
                <!-- 停止按钮颜色（单独定义） -->
                <SolidColorBrush x:Key="StopButtonColor"
                                 Color="#D97A6C"/>

                <!-- 通用按钮样式 -->
                <Style TargetType="Button">
                        <Setter Property="Background"
                                Value="{StaticResource AccentColor}"/>
                        <Setter Property="Foreground"
                                Value="White"/>
                        <Setter Property="Padding"
                                Value="10,5"/>
                        <Setter Property="Margin"
                                Value="4"/>
                        <Setter Property="FontWeight"
                                Value="SemiBold"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Height"
                                Value="32"/>
                        <!-- 移除 CornerRadius，因为 Button 不支持 -->
                        <Setter Property="Opacity"
                                Value="0.9"/>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Opacity"
                                                Value="1"/>
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                        <Setter Property="Opacity"
                                                Value="0.8"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- 停止按钮专用样式 -->
                <Style TargetType="Button"
                       x:Key="StopButton">
                        <Setter Property="Background"
                                Value="{StaticResource StopButtonColor}"/>
                        <Setter Property="Foreground"
                                Value="White"/>
                        <Setter Property="Padding"
                                Value="10,5"/>
                        <Setter Property="Margin"
                                Value="4"/>
                        <Setter Property="FontWeight"
                                Value="SemiBold"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Height"
                                Value="32"/>
                        <Setter Property="Opacity"
                                Value="0.9"/>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Opacity"
                                                Value="1"/>
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                        <Setter Property="Opacity"
                                                Value="0.8"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- 其他样式保持不变... -->
                <Style TargetType="TextBox">
                        <Setter Property="Margin"
                                Value="4"/>
                        <Setter Property="Padding"
                                Value="4"/>
                        <Setter Property="BorderBrush"
                                Value="#CCCCCC"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Height"
                                Value="28"/>
                        <Setter Property="VerticalContentAlignment"
                                Value="Center"/>
                        <Setter Property="Background"
                                Value="#FFFFFF"/>
                        <Setter Property="Foreground"
                                Value="#333333"/>
                </Style>

                <Style TargetType="Label">
                        <Setter Property="Margin"
                                Value="4,0"/>
                        <Setter Property="VerticalAlignment"
                                Value="Center"/>
                        <Setter Property="FontWeight"
                                Value="SemiBold"/>
                        <Setter Property="Foreground"
                                Value="#333333"/>
                </Style>

                <Style TargetType="TextBlock">
                        <Setter Property="Foreground"
                                Value="#333333"/>
                </Style>

                <Style TargetType="ListView">
                        <Setter Property="Background"
                                Value="White"/>
                        <Setter Property="Foreground"
                                Value="#333333"/>
                </Style>

                <Style TargetType="StatusBar">
                        <Setter Property="Background"
                                Value="#F5F5F5"/>
                </Style>

                <!-- 滑动开关样式 -->
                <Style x:Key="ToggleSwitch"
                       TargetType="CheckBox">
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                                <Grid>
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border x:Name="Track"
                                                                Grid.Column="0"
                                                                Width="40"
                                                                Height="22"
                                                                CornerRadius="11"
                                                                Background="#CCCCCC"
                                                                Cursor="Hand">
                                                                <Ellipse x:Name="Thumb"
                                                                         Width="18"
                                                                         Height="18"
                                                                         Fill="White"
                                                                         HorizontalAlignment="Left"
                                                                         Margin="2,2,0,2"
                                                                         RenderTransformOrigin="0.5,0.5">
                                                                        <Ellipse.RenderTransform>
                                                                                <TranslateTransform X="0"/>
                                                                        </Ellipse.RenderTransform>
                                                                </Ellipse>
                                                        </Border>
                                                        <ContentPresenter Grid.Column="1"
                                                                          Margin="8,0,0,0"
                                                                          VerticalAlignment="Center"
                                                                          Content="{TemplateBinding Content}"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked"
                                                                 Value="True">
                                                                <Setter TargetName="Track"
                                                                        Property="Background"
                                                                        Value="{StaticResource AccentColor}"/>
                                                                <Setter TargetName="Thumb"
                                                                        Property="RenderTransform">
                                                                        <Setter.Value>
                                                                                <TranslateTransform X="18"/>
                                                                        </Setter.Value>
                                                                </Setter>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled"
                                                                 Value="False">
                                                                <Setter TargetName="Track"
                                                                        Property="Opacity"
                                                                        Value="0.5"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="Track"
                                                                        Property="Opacity"
                                                                        Value="0.8"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>
        </Application.Resources>
</Application>