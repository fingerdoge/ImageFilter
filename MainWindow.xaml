<Window x:Class="Imagefilter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="图像筛选工具"
        Height="850"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
        <Grid Margin="15">
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 路径选择 -->
                <Border Grid.Row="0"
                        Background="White"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,10"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                        <StackPanel>
                                <WrapPanel Margin="0,0,0,6">
                                        <Label Content="读取路径："
                                               Width="80"/>
                                        <TextBox x:Name="txtSourcePath"
                                                 Width="420"/>
                                        <Button Content="浏览..."
                                                Click="BrowseSource_Click"
                                                Width="80"/>
                                        <CheckBox x:Name="chkRecursive"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  Content="包含子文件夹中图片"
                                                  IsChecked="True"
                                                  Margin="20,0,0,0"/>
                                </WrapPanel>
                                <WrapPanel>
                                        <Label Content="保存路径："
                                               Width="80"/>
                                        <TextBox x:Name="txtDestPath"
                                                 Width="420"/>
                                        <Button Content="浏览..."
                                                Click="BrowseDest_Click"
                                                Width="80"/>
                                </WrapPanel>
                        </StackPanel>
                </Border>

                <!-- 模式选择卡片（4个模式） -->
                <WrapPanel Grid.Row="1"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center">
                        <Button x:Name="btnNormal"
                                Content="📐 普通模式"
                                Width="140"
                                Height="50"
                                Margin="6,0"
                                Background="#0078D4"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="15"
                                Click="ModeButton_Click"
                                Tag="Normal"/>
                        <Button x:Name="btnWide"
                                Content="🖥️ 宽屏模式"
                                Width="140"
                                Height="50"
                                Margin="6,0"
                                Background="#6B6B6B"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="15"
                                Click="ModeButton_Click"
                                Tag="Wide"/>
                        <Button x:Name="btnAvatar"
                                Content="👤 头像模式（1:1）"
                                Width="160"
                                Height="50"
                                Margin="6,0"
                                Background="#6B6B6B"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="15"
                                Click="ModeButton_Click"
                                Tag="Avatar"/>
                        <Button x:Name="btnPortrait"
                                Content="📱 竖屏模式"
                                Width="140"
                                Height="50"
                                Margin="6,0"
                                Background="#6B6B6B"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="15"
                                Click="ModeButton_Click"
                                Tag="Portrait"/>
                </WrapPanel>

                <!-- 筛选条件面板 -->
                <Border Grid.Row="2"
                        Background="White"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,0,10"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                        <Grid>
                                <!-- ============ 宽屏模式 ============ -->
                                <StackPanel x:Name="panelWide"
                                            Visibility="Visible">
                                        <TextBlock Text="宽屏模式（宽度 &gt; 高度）"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Margin="0,0,0,10"/>
                                        <!-- 像素条件 -->
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkWideMaxW"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最大宽像素"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtWideMaxW"
                                                         Width="80"
                                                         Text="9999"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkWideMinW"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最小宽像素"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtWideMinW"
                                                         Width="80"
                                                         Text="0"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkWideMaxH"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最大高像素"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtWideMaxH"
                                                         Width="80"
                                                         Text="9999"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkWideMinH"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最小高像素"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtWideMinH"
                                                         Width="80"
                                                         Text="0"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <!-- 比例条件 -->
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkWideRatio"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="比例阈值"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <Label Content="宽"
                                                       Width="25"/>
                                                <TextBox x:Name="txtWideRatioW"
                                                         Width="55"
                                                         Text=""
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                                <Label Content=":"
                                                       Width="15"
                                                       HorizontalContentAlignment="Center"/>
                                                <TextBox x:Name="txtWideRatioH"
                                                         Width="55"
                                                         Text=""
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                                <Label Content="高"
                                                       Width="25"/>
                                                <CheckBox x:Name="chkWideRatioInvert"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="反选"
                                                          IsChecked="False"
                                                          Margin="20,0,0,0"
                                                          IsEnabled="False"/>
                                        </WrapPanel>
                                        <!-- 清晰度条件 -->
                                        <Canvas Height="60"
                                                Width="260"
                                                Margin="0,8,0,0">
                                                <ToggleButton x:Name="WideClaritySeg0"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="0"
                                                              Canvas.Top="0"/>
                                                <ToggleButton x:Name="WideClaritySeg1"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="65"
                                                              Canvas.Top="0"/>
                                                <ToggleButton x:Name="WideClaritySeg2"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="130"
                                                              Canvas.Top="0"/>
                                                <ToggleButton x:Name="WideClaritySeg3"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="195"
                                                              Canvas.Top="0"/>
                                                <TextBlock Text="0"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="0"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="1080p"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="65"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="2k"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="130"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="4k"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="195"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="4k+"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="260"
                                                           Canvas.Top="35"/>
                                        </Canvas>
                                </StackPanel>

                                <!-- ============ 普通模式（新增） ============ -->
                                <StackPanel x:Name="panelNormal"
                                            Visibility="Collapsed">
                                        <TextBlock Text="普通模式（不限方向）"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Margin="0,0,0,10"/>
                                        <!-- 像素条件 -->
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkNormalMaxW"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最大宽像素"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtNormalMaxW"
                                                         Width="80"
                                                         Text="9999"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkNormalMinW"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最小宽像素"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtNormalMinW"
                                                         Width="80"
                                                         Text="0"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkNormalMaxH"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最大高像素"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtNormalMaxH"
                                                         Width="80"
                                                         Text="9999"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkNormalMinH"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最小高像素"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtNormalMinH"
                                                         Width="80"
                                                         Text="0"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <!-- 比例条件 -->
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkNormalRatio"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="比例阈值"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <Label Content="宽"
                                                       Width="25"/>
                                                <TextBox x:Name="txtNormalRatioW"
                                                         Width="55"
                                                         Text=""
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                                <Label Content=":"
                                                       Width="15"
                                                       HorizontalContentAlignment="Center"/>
                                                <TextBox x:Name="txtNormalRatioH"
                                                         Width="55"
                                                         Text=""
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                                <Label Content="高"
                                                       Width="25"/>
                                                <CheckBox x:Name="chkNormalRatioInvert"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="反选"
                                                          IsChecked="False"
                                                          Margin="20,0,0,0"
                                                          IsEnabled="False"/>
                                        </WrapPanel>
                                        <!-- 清晰度条件 -->
                                        <Canvas Height="60"
                                                Width="260"
                                                Margin="0,8,0,0">
                                                <ToggleButton x:Name="NormalClaritySeg0"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="0"
                                                              Canvas.Top="0"/>
                                                <ToggleButton x:Name="NormalClaritySeg1"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="65"
                                                              Canvas.Top="0"/>
                                                <ToggleButton x:Name="NormalClaritySeg2"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="130"
                                                              Canvas.Top="0"/>
                                                <ToggleButton x:Name="NormalClaritySeg3"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="195"
                                                              Canvas.Top="0"/>
                                                <TextBlock Text="0"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="0"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="1080p"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="65"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="2k"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="130"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="4k"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="195"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="4k+"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="260"
                                                           Canvas.Top="35"/>
                                        </Canvas>
                                </StackPanel>

                                <!-- ============ 头像模式（误差2%） ============ -->
                                <StackPanel x:Name="panelAvatar"
                                            Visibility="Collapsed">
                                        <TextBlock Text="头像模式（1:1，允许误差 ±2%）"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Margin="0,0,0,10"/>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkAvatarMax"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最大边长"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtAvatarMax"
                                                         Width="80"
                                                         Text="9999"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkAvatarMin"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最小边长"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtAvatarMin"
                                                         Width="80"
                                                         Text="0"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <!-- 清晰度条件 -->
                                        <Canvas Height="60"
                                                Width="260"
                                                Margin="0,8,0,0">
                                                <ToggleButton x:Name="AvatarClaritySeg0"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="0"
                                                              Canvas.Top="0"/>
                                                <ToggleButton x:Name="AvatarClaritySeg1"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="65"
                                                              Canvas.Top="0"/>
                                                <ToggleButton x:Name="AvatarClaritySeg2"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="130"
                                                              Canvas.Top="0"/>
                                                <ToggleButton x:Name="AvatarClaritySeg3"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="195"
                                                              Canvas.Top="0"/>
                                                <TextBlock Text="0"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="0"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="1080p"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="65"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="2k"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="130"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="4k"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="195"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="4k+"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="260"
                                                           Canvas.Top="35"/>
                                        </Canvas>
                                </StackPanel>

                                <!-- ============ 竖屏模式 ============ -->
                                <StackPanel x:Name="panelPortrait"
                                            Visibility="Collapsed">
                                        <TextBlock Text="竖屏模式（宽度 &lt; 高度）"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Margin="0,0,0,10"/>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkPortraitMaxW"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最大宽像素"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtPortraitMaxW"
                                                         Width="80"
                                                         Text="9999"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkPortraitMinW"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最小宽像素"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtPortraitMinW"
                                                         Width="80"
                                                         Text="0"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkPortraitMaxH"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最大高像素"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtPortraitMaxH"
                                                         Width="80"
                                                         Text="9999"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkPortraitMinH"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="最小高像素"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <TextBox x:Name="txtPortraitMinH"
                                                         Width="80"
                                                         Text="0"
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4">
                                                <CheckBox x:Name="chkPortraitRatio"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="比例阈值"
                                                          IsChecked="False"
                                                          Width="160"/>
                                                <Label Content="宽"
                                                       Width="25"/>
                                                <TextBox x:Name="txtPortraitRatioW"
                                                         Width="55"
                                                         Text=""
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                                <Label Content=":"
                                                       Width="15"
                                                       HorizontalContentAlignment="Center"/>
                                                <TextBox x:Name="txtPortraitRatioH"
                                                         Width="55"
                                                         Text=""
                                                         PreviewTextInput="NumberValidationTextBox"
                                                         LostFocus="TextBox_LostFocus"
                                                         IsEnabled="False"/>
                                                <Label Content="高"
                                                       Width="25"/>
                                                <CheckBox x:Name="chkPortraitRatioInvert"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Content="反选"
                                                          IsChecked="False"
                                                          Margin="20,0,0,0"
                                                          IsEnabled="False"/>
                                        </WrapPanel>
                                        <!-- 清晰度条件 -->
                                        <Canvas Height="60"
                                                Width="260"
                                                Margin="0,8,0,0">
                                                <ToggleButton x:Name="PortraitClaritySeg0"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="0"
                                                              Canvas.Top="0"/>
                                                <ToggleButton x:Name="PortraitClaritySeg1"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="65"
                                                              Canvas.Top="0"/>
                                                <ToggleButton x:Name="PortraitClaritySeg2"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="130"
                                                              Canvas.Top="0"/>
                                                <ToggleButton x:Name="PortraitClaritySeg3"
                                                              Style="{StaticResource ClaritySegmentButton}"
                                                              Content=""
                                                              Width="65"
                                                              Height="30"
                                                              Canvas.Left="195"
                                                              Canvas.Top="0"/>
                                                <TextBlock Text="0"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="0"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="1080p"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="65"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="2k"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="130"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="4k"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="195"
                                                           Canvas.Top="35"/>
                                                <TextBlock Text="4k+"
                                                           Style="{StaticResource ClarityScaleLabel}"
                                                           Canvas.Left="260"
                                                           Canvas.Top="35"/>
                                        </Canvas>
                                </StackPanel>
                        </Grid>
                </Border>

                <!-- 操作按钮 -->
                <WrapPanel Grid.Row="3"
                           Margin="0,0,0,10">
                        <Button Content="🔍 开始筛选"
                                Click="StartFilter_Click"
                                Width="120"
                                Background="#0078D4"/>
                        <Button Content="⏹️ 停止筛选"
                                Click="StopFilter_Click"
                                Width="120"
                                Background="#C43E1C"
                                Foreground="White"
                                FontWeight="Bold"/>
                        <Button Content="📋 复制到保存路径"
                                Click="CopyToDest_Click"
                                Width="160"
                                Background="#2B5797"/>
                        <Button Content="✂️ 移动到保存路径"
                                Click="MoveToDest_Click"
                                Width="160"
                                Background="#C43E1C"/>
                        <Button Content="🗑️ 清空列表"
                                Click="ClearList_Click"
                                Width="100"
                                Background="#666"/>
                </WrapPanel>

                <!-- 结果列表 -->
                <Border Grid.Row="4"
                        Background="White"
                        CornerRadius="8"
                        Padding="8"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                        <Grid>
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="📋 筛选结果"
                                           FontWeight="Bold"
                                           Margin="0,0,0,6"/>
                                <ListView x:Name="listResults"
                                          Grid.Row="1"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListView.View>
                                                <GridView>
                                                        <GridViewColumn Header="文件名"
                                                                        Width="200"
                                                                        DisplayMemberBinding="{Binding FileName}"/>
                                                        <GridViewColumn Header="宽度"
                                                                        Width="70"
                                                                        DisplayMemberBinding="{Binding Width}"/>
                                                        <GridViewColumn Header="高度"
                                                                        Width="70"
                                                                        DisplayMemberBinding="{Binding Height}"/>
                                                        <GridViewColumn Header="长边"
                                                                        Width="70"
                                                                        DisplayMemberBinding="{Binding LongSide}"/>
                                                        <GridViewColumn Header="短边"
                                                                        Width="70"
                                                                        DisplayMemberBinding="{Binding ShortSide}"/>
                                                        <GridViewColumn Header="宽/高比"
                                                                        Width="80"
                                                                        DisplayMemberBinding="{Binding Ratio}"/>
                                                        <GridViewColumn Header="总像素"
                                                                        Width="80"
                                                                        DisplayMemberBinding="{Binding TotalPixels}"/>
                                                        <GridViewColumn Header="完整路径"
                                                                        Width="300"
                                                                        DisplayMemberBinding="{Binding FullPath}"/>
                                                </GridView>
                                        </ListView.View>
                                </ListView>
                        </Grid>
                </Border>

                <!-- 日志区域 -->
                <Border Grid.Row="5"
                        Background="White"
                        CornerRadius="8"
                        Padding="8"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        Margin="0,5,0,0">
                        <Grid>
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="📝 运行日志"
                                           FontWeight="Bold"
                                           Margin="0,0,0,4"/>
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto">
                                        <TextBox x:Name="txtLog"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 Background="#FAFAFA"
                                                 BorderBrush="#DDD"
                                                 FontFamily="Consolas"
                                                 FontSize="12"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Height="80"/>
                                </ScrollViewer>
                        </Grid>
                </Border>

                <!-- 状态栏 -->
                <StatusBar Grid.Row="6"
                           Margin="0,10,0,0"
                           Background="Transparent">
                        <StatusBarItem>
                                <TextBlock x:Name="statusBar"
                                           Text="就绪"/>
                        </StatusBarItem>
                </StatusBar>
        </Grid>
</Window>